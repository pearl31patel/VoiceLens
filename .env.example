# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1YOUR_TWILIO_NUMBER

# Must be your HTTPS ngrok/cloudflared/public URL, no trailing slash.
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

# AI services
OPENAI_API_KEY=sk-your-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

DEEPGRAM_API_KEY=your_deepgram_key

# Safety lock: this app refuses to call any number except this one.
ASSESSMENT_NUMBER=+18054398008

# Local output folder
CALL_OUTPUT_DIR=data/calls

# Call behavior
MAX_CALL_SECONDS=210
MAX_TURNS=12
